# Starship prompt - detect Nerd Font by terminal app
# Terminals we configure with Nerd Font: Ghostty, Alacritty, WezTerm, Zed, iTerm2, kitty
# Terminal.app and others: assume no Nerd Font
_starship_has_nerdfont=0
case "$TERM_PROGRAM" in
  ghostty|WezTerm|iTerm.app) _starship_has_nerdfont=1 ;;
  *)
    # Alacritty sets TERM=alacritty, kitty sets TERM=xterm-kitty
    case "$TERM" in
      alacritty|xterm-kitty) _starship_has_nerdfont=1 ;;
    esac
    ;;
esac
# Manual override
[ "$NERD_FONT" = "1" ] && _starship_has_nerdfont=1
[ "$NERD_FONT" = "0" ] && _starship_has_nerdfont=0

if [ "$_starship_has_nerdfont" = "1" ]; then
  _starship_full="$HOME/.config/starship.toml"
  _starship_compact="$HOME/.config/starship-compact.toml"
else
  _starship_full="$HOME/.config/starship-plain.toml"
  _starship_compact="$HOME/.config/starship-plain.toml"
fi
export STARSHIP_CONFIG="$_starship_full"

# Platform default shell — hide it from prompt (no need to show the obvious)
case "$(uname -s)" in
  Darwin)          _starship_default_shell="zsh" ;;
  MINGW*|MSYS*)    _starship_default_shell="bash" ;;  # Git Bash on Windows
  *)               _starship_default_shell="bash" ;;
esac

[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env" || true
