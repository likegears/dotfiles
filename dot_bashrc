# remove bash warning
export BASH_SILENCE_DEPRECATION_WARNING=1

# ── XDG Base Directory (guard: skip if inherited from zsh) ──
if [ -z "$XDG_CONFIG_HOME" ]; then
  export XDG_CONFIG_HOME="$HOME/.config"
  export XDG_DATA_HOME="$HOME/.local/share"
  export XDG_CACHE_HOME="$HOME/.cache"
  export XDG_STATE_HOME="$HOME/.local/state"

  # Rust
  export CARGO_HOME="$XDG_DATA_HOME/cargo"
  export RUSTUP_HOME="$XDG_DATA_HOME/rustup"
  [ -f "$CARGO_HOME/env" ] && . "$CARGO_HOME/env"

  # Bun
  export BUN_INSTALL="$XDG_DATA_HOME/bun"
  export PATH="$BUN_INSTALL/bin:$PATH"

  # npm / pnpm
  export NPM_CONFIG_CACHE="$XDG_CACHE_HOME/npm"
  export PNPM_HOME="$XDG_DATA_HOME/pnpm"
  export PNPM_STORE_DIR="$XDG_DATA_HOME/pnpm/store"
  export PATH="$PNPM_HOME:$PATH"

  # Docker
  export DOCKER_CONFIG="$XDG_CONFIG_HOME/docker"

  # GnuPG
  export GNUPGHOME="$XDG_DATA_HOME/gnupg"

  # History / State
  export HISTFILE="$XDG_STATE_HOME/bash/history"
  export LESSHISTFILE="$XDG_STATE_HOME/less/history"
  export VIMINFOFILE="$XDG_STATE_HOME/vim/viminfo"

  # Conda
  export CONDARC="$XDG_CONFIG_HOME/conda/condarc"

  # Maven
  export MAVEN_OPTS="-Dmaven.user.settings=$XDG_CONFIG_HOME/maven/settings.xml $MAVEN_OPTS"

  # Matplotlib
  export MPLCONFIGDIR="$XDG_CONFIG_HOME/matplotlib"

  # Claude Code
  export CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=70
fi

# Shell display: hide platform default shell (macOS=zsh, Linux=bash)
if [ "$_starship_default_shell" = "bash" ]; then
  unset STARSHIP_SHELL_DISPLAY
else
  export STARSHIP_SHELL_DISPLAY=" bsh"
fi

# ── Starship prompt ──────────────────────────
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init bash)"

  _starship_adaptive_prompt() {
    if [ "${COLUMNS:-120}" -lt 100 ] 2>/dev/null; then
      export STARSHIP_CONFIG="$_starship_compact"
    else
      export STARSHIP_CONFIG="$_starship_full"
    fi
  }
  PROMPT_COMMAND="_starship_adaptive_prompt;${PROMPT_COMMAND}"
fi

# ── Editor ───────────────────────────────────
export EDITOR="nvim"
export VISUAL="zed"

# ── SSH (1Password) ──────────────────────────
if [[ "$OSTYPE" == darwin* ]]; then
  export SSH_AUTH_SOCK=~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock
else
  export SSH_AUTH_SOCK=~/.1password/agent.sock
fi

# ── PATH ─────────────────────────────────────
[ -d "/opt/homebrew/opt/mysql-client/bin" ] && export PATH="/opt/homebrew/opt/mysql-client/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
PATH="$PATH:./"
[ -d "$HOME/Library/Application Support/JetBrains/Toolbox/scripts" ] && export PATH="$PATH:$HOME/Library/Application Support/JetBrains/Toolbox/scripts"
[ -d "/System/Volumes/Data/Applications/Obsidian.app" ] && export PATH="$PATH:/System/Volumes/Data/Applications/Obsidian.app/Contents/MacOS"
[ -d "$HOME/.antigravity" ] && export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# ── Aliases ──────────────────────────────────
alias cc='claude --dangerously-skip-permissions'
alias wget='wget --hsts-file="$XDG_STATE_HOME/wget/hsts"'

# ── Secrets from 1Password ───────────────────
[ -f "$XDG_CONFIG_HOME/env.secrets" ] && source "$XDG_CONFIG_HOME/env.secrets"

# ── Catppuccin auto theme ────────────────────
_catppuccin_flavor() {
  if [[ "$OSTYPE" == darwin* ]]; then
    [[ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" == "Dark" ]] && echo "frappe" || echo "latte"
  else
    echo "frappe"
  fi
}

if [[ "$(_catppuccin_flavor)" == "frappe" ]]; then
  export FZF_DEFAULT_OPTS=" \
    --color=bg+:#414559,spinner:#f2d5cf,hl:#e78284 \
    --color=fg:#c6d0f5,header:#e78284,info:#ca9ee6,pointer:#f2d5cf \
    --color=marker:#babbf1,fg+:#c6d0f5,prompt:#ca9ee6,hl+:#e78284 \
    --color=border:#8caaee"
else
  export FZF_DEFAULT_OPTS=" \
    --color=bg+:#ccd0da,spinner:#dc8a78,hl:#d20f39 \
    --color=fg:#4c4f69,header:#d20f39,info:#8839ef,pointer:#dc8a78 \
    --color=marker:#7287fd,fg+:#4c4f69,prompt:#8839ef,hl+:#d20f39 \
    --color=border:#1e66f5"
fi

zj() {
  local theme
  if [[ "$OSTYPE" == darwin* ]]; then
    if [[ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" == "Dark" ]]; then
      theme="catppuccin-mocha-vivid"
    else
      theme="catppuccin-frappe-vivid"
    fi
  else
    theme="catppuccin-mocha-vivid"
  fi
  command zellij options --theme "$theme" 2>/dev/null
  command zellij "$@"
}

lg() {
  local f=$(_catppuccin_flavor)
  LG_CONFIG_FILE="$HOME/.config/lazygit/config.yml,$HOME/.config/lazygit/theme-${f}.yml" \
    command lazygit "$@"
}

lzd() {
  local f=$(_catppuccin_flavor)
  command cp "$HOME/.config/lazydocker/theme-${f}.yml" "$HOME/.config/lazydocker/config.yml"
  command lazydocker "$@"
}

bt() {
  local f=$(_catppuccin_flavor)
  if [[ "$OSTYPE" == darwin* ]]; then
    sed -i '' "s|color_theme = .*|color_theme = \"$HOME/.config/btop/themes/catppuccin_${f}.theme\"|" \
      "$HOME/.config/btop/btop.conf"
  else
    sed -i "s|color_theme = .*|color_theme = \"$HOME/.config/btop/themes/catppuccin_${f}.theme\"|" \
      "$HOME/.config/btop/btop.conf"
  fi
  command btop "$@"
}

# ── Tool inits ───────────────────────────────
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
command -v direnv >/dev/null 2>&1 && eval "$(direnv hook bash)"
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init bash)"
[ -f ~/.orbstack/shell/init.bash ] && source ~/.orbstack/shell/init.bash 2>/dev/null
