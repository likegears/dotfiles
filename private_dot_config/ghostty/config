# auto theme switch
theme = dark:catppuccin-frappe.conf,light:catppuccin-latte.conf
# font-family = "ComicShannsMono Nerd Font Mono"
font-family = "3720 Nerd Font Mono"
cursor-opacity = 0.8
cursor-style = block
cursor-style-blink = true
mouse-hide-while-typing = true
background-opacity = 0.6
background-blur = 20
macos-titlebar-style = tabs

# Allow Shift+Enter to insert newline
keybind = shift+enter=text:\x0a
