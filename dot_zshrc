# Starship prompt init - auto-detect Nerd Font
if fc-list 2>/dev/null | grep -qi "nerd" \
  || [[ -n $(ls ~/Library/Fonts/*erd* /Library/Fonts/*erd* /usr/share/fonts/**/[Nn]erd* 2>/dev/null | head -1) ]] \
  || [[ "$NERD_FONT" == "1" ]]; then
  export STARSHIP_CONFIG=~/.config/starship.toml
else
  export STARSHIP_CONFIG=~/.config/starship-plain.toml
fi
eval "$(starship init zsh)"

