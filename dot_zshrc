# Source shared profile if not already loaded (non-login shells)
[ -z "$_starship_full" ] && . "$HOME/.profile"

# Shell display: hide platform default shell (macOS=zsh, Linux=bash)
if [ "$_starship_default_shell" = "zsh" ]; then
  unset STARSHIP_SHELL_DISPLAY
else
  export STARSHIP_SHELL_DISPLAY=" zsh"
fi

# Starship prompt init
# STARSHIP_CONFIG is set in .zshenv (nerd font detection by terminal app)
eval "$(starship init zsh)"

# run local files
PATH="$PATH:./"

#set default editor
export EDITOR="nvim"
export VISUAL="zed"

export SSH_AUTH_SOCK=~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock
export PATH="/opt/homebrew/opt/mysql-client/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
# wget XDG alias
alias wget='wget --hsts-file="$XDG_STATE_HOME/wget/hsts"'
alias cc='claude --dangerously-skip-permissions'

# ── Secrets from 1Password ────────────────────
[ -f "$XDG_CONFIG_HOME/env.secrets" ] && source "$XDG_CONFIG_HOME/env.secrets"

# ── Catppuccin auto theme (dark=frappe, light=latte) ──
_catppuccin_flavor() {
  [[ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" == "Dark" ]] && echo "frappe" || echo "latte"
}

# fzf — set colors at shell startup (no wrapper needed, fzf reads env var)
if [[ "$(_catppuccin_flavor)" == "frappe" ]]; then
  export FZF_DEFAULT_OPTS=" \
    --color=bg+:#414559,spinner:#f2d5cf,hl:#e78284 \
    --color=fg:#c6d0f5,header:#e78284,info:#ca9ee6,pointer:#f2d5cf \
    --color=marker:#babbf1,fg+:#c6d0f5,prompt:#ca9ee6,hl+:#e78284 \
    --color=border:#8caaee"
else
  export FZF_DEFAULT_OPTS=" \
    --color=bg+:#ccd0da,spinner:#dc8a78,hl:#d20f39 \
    --color=fg:#4c4f69,header:#d20f39,info:#8839ef,pointer:#dc8a78 \
    --color=marker:#7287fd,fg+:#4c4f69,prompt:#8839ef,hl+:#d20f39 \
    --color=border:#1e66f5"
fi

zj() {
  local theme
  if [[ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" == "Dark" ]]; then
    theme="catppuccin-mocha-vivid"
  else
    theme="catppuccin-frappe-vivid"
  fi
  command zellij options --theme "$theme" 2>/dev/null
  command zellij "$@"
}

lg() {
  local f=$(_catppuccin_flavor)
  LG_CONFIG_FILE="$HOME/.config/lazygit/config.yml,$HOME/.config/lazygit/theme-${f}.yml" \
    command lazygit "$@"
}

lzd() {
  local f=$(_catppuccin_flavor)
  command cp "$HOME/.config/lazydocker/theme-${f}.yml" "$HOME/.config/lazydocker/config.yml"
  command lazydocker "$@"
}

