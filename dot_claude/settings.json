{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": " ",
    "pr": " "
  },
  "permissions": {
    "defaultMode": "default"
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Before compacting, review this conversation and extract valuable knowledge. Apply these rules:\n\n1. **User preferences, habits, feedback** → Save to auto memory system (memory files)\n2. **Project-specific conventions, architecture decisions, code patterns** → Append to the project's CLAUDE.md (create if needed)\n3. **Reusable workflows or multi-step patterns that would help in future sessions** → Consider noting them for potential skill creation\n4. **Temporary, one-off, or already-documented information** → Skip, do not save\n\nBe selective — only save things that would genuinely be useful in future sessions. Do not duplicate what already exists in memory or CLAUDE.md."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": false,
    "serena@claude-plugins-official": false,
    "code-review@claude-plugins-official": true,
    "gitlab@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false,
    "clangd-lsp@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "superpowers@superpowers-marketplace": true,
    "plugin-dev@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "Notion@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "stripe@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false,
    "sentry@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "huggingface-skills@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": false,
    "double-shot-latte@superpowers-marketplace": true,
    "figma@claude-plugins-official": true,
    "greptile@claude-plugins-official": false,
    "lua-lsp@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": false,
    "php-lsp@claude-plugins-official": false,
    "jdtls-lsp@claude-plugins-official": false
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
