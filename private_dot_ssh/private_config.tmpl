{{- $isWSL := ne (env "WSL_DISTRO_NAME") "" -}}
{{- $useLinuxAgent := and (eq .chezmoi.os "linux") (not $isWSL) -}}
{{ if eq .chezmoi.os "darwin" }}
Include ~/.orbstack/ssh/config
{{ end }}
# ── Git Hosting ──────────────────────────────

Host github.com
	User git
	IdentityFile ~/.local/share/ssh/1password/jhkfyppiwejxno2dxq6ppck25e.pub
{{ if eq .chezmoi.os "darwin" }}	IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"{{ else if $useLinuxAgent }}	IdentityAgent "~/.1password/agent.sock"{{ end }}

Host gitea.likegears.com
	User git
	Port 33233
	IdentityFile ~/.local/share/ssh/1password/dm5cz4tpjemtqbyk4hylgeachi.pub
{{ if eq .chezmoi.os "darwin" }}	IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"{{ else if $useLinuxAgent }}	IdentityAgent "~/.1password/agent.sock"{{ end }}

